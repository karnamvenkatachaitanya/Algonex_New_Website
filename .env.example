# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=algonex
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# OAuth (optional — get from Google/GitHub developer console)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email (required for password reset and registration invites)
# For development, Django uses console backend (prints to terminal).
# For production, configure SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Caddy / Domain
DOMAIN=localhost

# Buddy AI Chatbot (get your key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
# To switch provider, set BUDDY_LLM_PROVIDER=openai and add:
# OPENAI_API_KEY=
